{
	"name": "misaf/vendra-tenant",
	"description": "Multi-tenancy management system with isolated data and configuration per tenant",
	"license": "MIT",
	"type": "vendra-module",
	"keywords": [
		"laravel",
		"filamentphp",
		"tenant"
	],
	"authors": [
		{
			"name": "Ehsan Mahmoodi",
			"email": "misaf.1990@gmail.com"
		}
	],
	"require": {
		"php": "^8.3",
		"filament/filament": "^5.0",
		"illuminate/support": "^13.0",
		"misaf/vendra-activity-log": "dev-master",
		"misaf/vendra-support": "dev-master",
		"spatie/laravel-activitylog": "^4.0",
		"spatie/laravel-multitenancy": "^4.0.5",
		"spatie/laravel-package-tools": "^1.0",
		"spatie/laravel-sluggable": "^4.0",
		"staudenmeir/belongs-to-through": "^2.0",
		"staudenmeir/eloquent-has-many-deep": "^1.0"
	},
	"require-dev": {
		"fakerphp/faker": "^1.0",
		"larastan/larastan": "^3.0",
		"laravel/boost": "^2.0",
		"laravel/pint": "^1.0",
		"mockery/mockery": "^1.0",
		"nunomaduro/collision": "^8.0",
		"orchestra/testbench": "^11.0",
		"pestphp/pest": "^4.0",
		"pestphp/pest-plugin-laravel": "^4.0",
		"phpstan/extension-installer": "^1.4"
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"autoload": {
		"psr-4": {
			"Misaf\\VendraTenant\\": "src/",
			"Misaf\\VendraTenant\\Database\\Seeders\\": "database/seeders/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Misaf\\VendraTenant\\Database\\Factories\\": "database/factories/",
			"Misaf\\VendraTenant\\Tests\\": "tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true,
			"php-http/discovery": true,
			"phpstan/extension-installer": true
		},
		"optimize-autoloader": true,
		"preferred-install": "dist",
		"sort-packages": true
	},
	"extra": {
		"laravel": {
			"providers": [
				"Misaf\\VendraTenant\\Providers\\TenantServiceProvider"
			]
		}
	},
	"scripts": {
		"analyse": "vendor/bin/phpstan analyse",
		"format": "vendor/bin/pint",
		"test": "vendor/bin/pest",
		"test-coverage": "vendor/bin/pest --coverage"
	},
	"$schema": "https://getcomposer.org/schema.json"
}
